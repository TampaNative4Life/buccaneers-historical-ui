/*===========================================================
COMBINED OFFENSE VIEW
===========================================================*/
IF OBJECT_ID('dbo.vwOffenseCombined','V') IS NOT NULL
DROP VIEW dbo.vwOffenseCombined;
GO

CREATE VIEW dbo.vwOffenseCombined
AS

SELECT
'Passing' StatType,
SeasonYear,
PlayerName,
Attempts,
Completions,
Yards,
TD
FROM dbo.tblPassing

UNION ALL

SELECT
'Rushing',
SeasonYear,
PlayerName,
Attempts,
NULL,
Yards,
TD
FROM dbo.tblRushing

UNION ALL

SELECT
'Receiving',
SeasonYear,
PlayerName,
Receptions,
NULL,
Yards,
TD
FROM dbo.tblReceiving;
GO


/*===========================================================
PLAYER SEASON SUMMARY
===========================================================*/
IF OBJECT_ID('dbo.vwPlayerSeasonSummary','V') IS NOT NULL
DROP VIEW dbo.vwPlayerSeasonSummary;
GO

CREATE VIEW dbo.vwPlayerSeasonSummary
AS

WITH PlayerKeys AS
(
SELECT DISTINCT SeasonYear, PlayerName FROM dbo.tblPassing
UNION
SELECT DISTINCT SeasonYear, PlayerName FROM dbo.tblRushing
UNION
SELECT DISTINCT SeasonYear, PlayerName FROM dbo.tblReceiving
)

SELECT
k.SeasonYear,
k.PlayerName,

p.Yards AS PassYds,
p.TD AS PassTD,
p.INTs AS PassINT,

r.Yards AS RushYds,
r.TD AS RushTD,

c.Yards AS RecYds,
c.TD AS RecTD

FROM PlayerKeys k

LEFT JOIN dbo.tblPassing p
ON k.SeasonYear = p.SeasonYear
AND k.PlayerName = p.PlayerName

LEFT JOIN dbo.tblRushing r
ON k.SeasonYear = r.SeasonYear
AND k.PlayerName = r.PlayerName

LEFT JOIN dbo.tblReceiving c
ON k.SeasonYear = c.SeasonYear
AND k.PlayerName = c.PlayerName;
GO


