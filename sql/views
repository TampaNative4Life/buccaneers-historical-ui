/*===========================================================
PLAYER SEARCH VIEW
===========================================================*/
IF OBJECT_ID('dbo.vwPlayerSearch','V') IS NOT NULL
DROP VIEW dbo.vwPlayerSearch;
GO

CREATE VIEW dbo.vwPlayerSearch
AS
SELECT
    PlayerID,
    SeasonYear,
    JerseyNumber,
    Forename,
    Surname,
    FullName,
    Position,
    Team,
    Height,
    Weight,
    BirthDate,
    College
FROM dbo.tblPlayers;
